<file path="rocky-calculator/src/__tests__/calculatorEngine.test.ts">
import { evaluate, formatResult, tokenize } from '@/lib/calculatorEngine';

describe('Calculator Engine', () => {
  describe('tokenize', () => {
    it('should tokenize simple numbers', () => {
      const tokens = tokenize('42');
      expect(tokens).toEqual([{ type: 'number', value: 42 }]);
    });

    it('should tokenize decimal numbers', () => {
      const tokens = tokenize('3.14');
      expect(tokens).toEqual([{ type: 'number', value: 3.14 }]);
    });

    it('should tokenize a simple expression', () => {
      const tokens = tokenize('2+3');
      expect(tokens).toEqual([
        { type: 'number', value: 2 },
        { type: 'operator', value: '+' },
        { type: 'number', value: 3 },
      ]);
    });

    it('should tokenize negative numbers at the start', () => {
      const tokens = tokenize('-5');
      expect(tokens).toEqual([{ type: 'number', value: -5 }]);
    });

    it('should tokenize parentheses', () => {
      const tokens = tokenize('(2+3)');
      expect(tokens).toEqual([
        { type: 'paren', value: '(' },
        { type: 'number', value: 2 },
        { type: 'operator', value: '+' },
        { type: 'number', value: 3 },
        { type: 'paren', value: ')' },
      ]);
    });

    it('should throw on invalid characters', () => {
      expect(() => tokenize('2+abc')).toThrow('Unexpected character');
    });
  });

  describe('evaluate', () => {
    it('should evaluate simple addition', () => {
      expect(evaluate('2+3')).toBe(5);
    });

    it('should evaluate simple subtraction', () => {
      expect(evaluate('10-4')).toBe(6);
    });

    it('should evaluate simple multiplication', () => {
      expect(evaluate('3*7')).toBe(21);
    });

    it('should evaluate simple division', () => {
      expect(evaluate('20/4')).toBe(5);
    });

    it('should respect operator precedence (multiplication before addition)', () => {
      expect(evaluate('2+3*4')).toBe(14);
    });

    it('should respect operator precedence (division before subtraction)', () => {
      expect(evaluate('10-6/2')).toBe(7);
    });

    it('should handle parentheses', () => {
      expect(evaluate('(2+3)*4')).toBe(20);
    });

    it('should handle nested parentheses', () => {
      expect(evaluate('((2+3)*4)+1')).toBe(21);
    });

    it('should handle negative numbers', () => {
      expect(evaluate('-5+3')).toBe(-2);
    });

    it('should handle decimal numbers', () => {
      expect(evaluate('0.1+0.2')).toBeCloseTo(0.3);
    });

    it('should handle complex expressions', () => {
      expect(evaluate('2+3*4-6/2')).toBe(11);
    });

    it('should throw on division by zero', () => {
      expect(() => evaluate('5/0')).toThrow('Division by zero');
    });

    it('should handle percentage', () => {
      expect(evaluate('50%')).toBe(0.5);
    });

    it('should evaluate single number', () => {
      expect(evaluate('42')).toBe(42);
    });

    it('should handle spaces in expression', () => {
      expect(evaluate('2 + 3')).toBe(5);
    });

    it('